{
  "name": "atlas",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "wrangler pages dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc -p functions/tsconfig.json --noEmit",
    "deploy": "npm run build && wrangler pages deploy",
    "electron:dev": "node scripts/set-share-origin.mjs && concurrently -k \"vite build --watch\" \"wait-on dist/index.html && electronmon electron/main.js\"",
    "electron:build": "node scripts/set-share-origin.mjs && npm run build && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucene": "^2.1.1",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.0",
    "shadcn": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@eslint/js": "^10",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "concurrently": "^10",
    "electron": "^42",
    "electron-builder": "^26",
    "electronmon": "^2",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vite": "^8",
    "wait-on": "^9",
    "wrangler": "^4"
  }
}
